rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow reading and writing user accounts
    match /users/{userId} {
      allow read, write: if true;
    }
    
    // Allow public reading of issues and creations/updates by community members
    match /issues/{issueId} {
      allow read, write: if true;
      
      // Allow cascading discussion comments for community coordination
      match /comments/{commentId} {
        allow read, write: if true;
      }
    }
  }
}
